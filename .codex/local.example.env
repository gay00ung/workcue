# Copy to .codex/local.env and fill with local-only paths.
# Do not commit .codex/local.env.

export WORKCUE_REPO="/absolute/path/to/workcue"
export WORKCUE_OBSIDIAN_REPO="/absolute/path/to/obsidian-vault"
export WORKCUE_KB_ROOT="$WORKCUE_OBSIDIAN_REPO/workcue"
export WORKCUE_PRODUCT_PLAN="$WORKCUE_KB_ROOT/workcue-product-plan.md"
export CODEX_HARNESS_SKILL_ROOT="$HOME/.codex/skills/codex-harness"
