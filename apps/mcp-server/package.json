{
  "name": "@workcue/mcp-server",
  "version": "0.1.0-alpha.1",
  "description": "MCP stdio server for WorkCue morning briefs.",
  "type": "module",
  "private": false,
  "bin": {
    "workcue-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/server.js"
  },
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@workcue/config": "workspace:*",
    "@workcue/runtime": "workspace:*",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "tsx": "^4.20.0"
  }
}
