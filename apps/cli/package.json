{
  "name": "workcue",
  "version": "0.1.0-alpha.2",
  "description": "Local-first morning brief CLI for work scattered across existing tools.",
  "type": "module",
  "private": false,
  "bin": {
    "workcue": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@workcue/cache-sqlite": "workspace:*",
    "@workcue/config": "workspace:*",
    "@workcue/runtime": "workspace:*",
    "commander": "^14.0.0"
  }
}
